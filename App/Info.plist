<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Merged with the generated Info.plist (GENERATE_INFOPLIST_FILE=YES +
         INFOPLIST_FILE set → Xcode merges; explicit keys here win). Only keys
         that have no INFOPLIST_KEY_* build-setting equivalent belong here.
         UIBackgroundModes: CloudKit silent pushes (sync while backgrounded);
         without it, sync still works but only while foregrounded. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>
    <!-- Plan 16 backups: expose Documents (→ Backups/) in the Files app and
         Finder. UIFileSharingEnabled has no effective INFOPLIST_KEY_* build
         setting (verified: the key never reached the built plist that way),
         so it lives here; its companion LSSupportsOpeningDocumentsInPlace is
         set via INFOPLIST_KEY_ in project.yml. Plain plist keys, NOT
         entitlements. -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <!-- Plan 24 webhooks: plain-HTTP deliveries are allowed ONLY to
         local-network hosts (the Home Assistant case) via the SCOPED
         NSAllowsLocalNetworking key — deliberately NOT
         NSAllowsArbitraryLoads. Plain plist key, NOT an entitlement; the
         kit-side URL rule additionally rejects non-local http URLs at
         entry. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <!-- Plan 25 iCloud Drive backups: make the ubiquity container's Documents
         scope a visible "Dispatch" folder in iCloud Drive (Files/Finder).
         Apple caches container visibility aggressively — if the folder
         doesn't appear on device, bump the build number and/or reboot. -->
    <key>NSUbiquitousContainers</key>
    <dict>
        <key>iCloud.io.robbie.Dispatch</key>
        <dict>
            <key>NSUbiquitousContainerIsDocumentScopePublic</key>
            <true/>
            <key>NSUbiquitousContainerName</key>
            <string>Dispatch</string>
            <key>NSUbiquitousContainerSupportedFolderLevels</key>
            <string>Any</string>
        </dict>
    </dict>
    <!-- dispatch:// deep links — scoped to WIDGET TAPS only (widgetURL/Link
         from the home/lock screen widgets). Per Apple's widget docs
         ("Respond to user interactions"), tap-to-open-app from a widget is
         URL-based by design. The Control Center control does NOT use this
         scheme; it opens the app via StartReportControlIntent (OpenIntent). -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>io.robbie.Dispatch</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>dispatch</string>
            </array>
        </dict>
        <!-- Plan 26 Spotify auth callback. Deliberately a SEPARATE scheme
             from the widget-tap `dispatch` scheme so onOpenURL routing stays
             unambiguous. Must match SpotifyRedirectURI below AND the redirect
             URI registered on the Spotify developer dashboard. -->
        <dict>
            <key>CFBundleURLName</key>
            <string>io.robbie.Dispatch.spotify</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>dispatch-spotify</string>
            </array>
        </dict>
    </array>
    <!-- Plan 26: lets SpotifySettingsView check whether the Spotify app is
         installed via canOpenURL (App Remote requires the real app). -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>spotify</string>
    </array>
    <!-- Plan 26 Spotify config (config, not code constants). PASTE the client
         ID from the Spotify developer dashboard app registration over the
         placeholder; the redirect URI must be registered there verbatim.
         While the placeholder is present, SpotifySettingsView shows a
         "not configured" state and the reader never runs. -->
    <key>SpotifyClientID</key>
    <string>SPOTIFY_CLIENT_ID_PLACEHOLDER</string>
    <key>SpotifyRedirectURI</key>
    <string>dispatch-spotify://callback</string>
</dict>
</plist>
